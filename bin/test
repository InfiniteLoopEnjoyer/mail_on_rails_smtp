#!/bin/bash -e
# Run the test suite without loading Rails or any host app. The bundle is
# used only to resolve gem dependencies (mail, minitest); Bundler.setup
# puts them on the load path without requiring anything.
cd "$(dirname "$0")/.."
exec bundle exec ruby -Ilib -Itest \
  -e 'Dir.glob("test/**/*_test.rb").sort.each { |f| require File.expand_path(f) }'
