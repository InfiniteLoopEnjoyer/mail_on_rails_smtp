#!/usr/bin/env ruby
# frozen_string_literal: true

# Entrypoint for the mail_on_rails_smtp Kamal service (config/deploy.yml):
# runs the SMTP listeners (MX + submission) in the foreground, no Rails and
# no database anywhere in the process. Credential checks, recipient
# validation, and outbound queueing go to the host app's private HTTP API
# (SMTP_INTERNAL_API_URL); accepted inbound mail goes to its
# Action Mailbox relay ingress (SMTP_INGRESS_URL).

require "bundler/setup"
$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

# Worker Ractors and the fiber scheduler's IO::Buffer use both carry
# experimental-API warnings; one line each at boot says nothing useful in
# production logs.
Warning[:experimental] = false

# Config is loaded first so a typed-ENV failure raised while the rest of
# the gem loads (listener caps and friends are read at require time) can
# be caught and reported as one clean line instead of a backtrace.
require "mail_on_rails/smtp/config"

begin
  require "mail_on_rails/smtp/daemon"
rescue MailOnRails::Smtp::Config::Error => e
  warn "[mail_on_rails] config error: #{e.message}"
  exit 1
end

# Deploy preflight: validate configuration and exit without serving.
if ARGV.include?("--check-config")
  exit(MailOnRails::Smtp::Daemon.check_config ? 0 : 1)
end

MailOnRails::Smtp::Daemon.run!