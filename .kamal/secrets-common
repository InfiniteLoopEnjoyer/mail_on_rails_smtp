# Secrets referenced in config/deploy.yml, shared across every deploy
# destination (kamal loads .kamal/secrets-common plus the destination's
# own file, if any). The values come from the gitignored .env file in the
# project root, which the deploy config's ERB header loads into the
# environment (via dotenv) before this file is resolved. They must match
# what the host app expects:
#
#   SMTP_INTERNAL_API_PASSWORD  - basic-auth password of the app's private internal API
#   SMTP_INGRESS_PASSWORD       - the app's Action Mailbox ingress password
SMTP_INTERNAL_API_PASSWORD=$SMTP_INTERNAL_API_PASSWORD
SMTP_INGRESS_PASSWORD=$SMTP_INGRESS_PASSWORD
