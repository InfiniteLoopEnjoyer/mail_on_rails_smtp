#!/bin/bash
set -e

# Kamal boots new containers before stopping old ones. This service
# publishes host ports (25/587/465), so a new daemon can't bind while its
# predecessor runs - stop the old one first. Costs a few seconds of SMTP
# downtime per deploy (peers retry).

[ "$KAMAL_SERVICE" = "mail_on_rails_smtp" ] || exit 0

IFS=',' read -ra HOSTS <<< "$KAMAL_HOSTS"
for host in "${HOSTS[@]}"; do
  ssh "root@$host" "docker ps -q --filter label=service=$KAMAL_SERVICE | xargs -r docker stop" \
      && echo "Stopped old $KAMAL_SERVICE container on $host (freeing its ports)"
done
